<div class="bg-gray-900 rounded-xl border border-gray-800 p-6 fade-in">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-semibold text-white">Status do Servidor</h2>
    <button id="restart-tunnel-btn" onclick="restartTunnel()"
      class="<%= status.tunnel.up ? 'hidden' : '' %> inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium rounded-lg bg-red-600 text-white hover:bg-red-500 transition-all shadow-lg shadow-red-900/30">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
      Reiniciar Tunnel
    </button>
  </div>

  <div class="grid grid-cols-2 sm:grid-cols-3 gap-4" id="status-grid">
    <!-- Tunnel -->
    <div class="space-y-1">
      <p class="text-xs text-gray-500 uppercase tracking-wider">Tunnel</p>
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full <%= status.tunnel.up ? 'bg-green-400 pulse-dot' : 'bg-red-400' %>"></span>
        <span class="text-sm font-medium <%= status.tunnel.up ? 'text-green-400' : 'text-red-400' %>">
          <%= status.tunnel.up ? 'Ativo' : 'Inativo' %>
        </span>
      </div>
      <% if (status.tunnel.iface) { %>
        <p class="text-xs text-gray-500"><%= status.tunnel.iface %></p>
      <% } %>
    </div>

    <!-- IP Forwarding -->
    <div class="space-y-1">
      <p class="text-xs text-gray-500 uppercase tracking-wider">IP Forwarding</p>
      <span class="text-sm font-medium <%= status.ipForwarding ? 'text-green-400' : 'text-red-400' %>">
        <%= status.ipForwarding ? 'Ativado' : 'Desativado' %>
      </span>
    </div>

    <!-- NAT -->
    <div class="space-y-1">
      <p class="text-xs text-gray-500 uppercase tracking-wider">NAT</p>
      <span class="text-sm font-medium <%= status.nat ? 'text-green-400' : 'text-yellow-400' %>">
        <%= status.nat ? 'Ativo' : 'Sem regras' %>
      </span>
    </div>

    <!-- Public IP -->
    <div class="space-y-1">
      <p class="text-xs text-gray-500 uppercase tracking-wider">Public IP</p>
      <span class="text-sm font-mono text-gray-300 break-all"><%= status.publicIp || 'N/A' %></span>
    </div>

    <!-- WG Daemon -->
    <div class="space-y-1">
      <p class="text-xs text-gray-500 uppercase tracking-wider">WG Daemon</p>
      <span class="text-sm font-medium <%= status.daemons.wireguard ? 'text-green-400' : 'text-gray-500' %>">
        <%= status.daemons.wireguard ? 'Carregado' : 'Parado' %>
      </span>
    </div>

    <!-- DuckDNS Daemon -->
    <div class="space-y-1">
      <p class="text-xs text-gray-500 uppercase tracking-wider">DuckDNS</p>
      <span class="text-sm font-medium <%= status.daemons.duckdns ? 'text-green-400' : 'text-gray-500' %>">
        <%= status.daemons.duckdns ? 'Carregado' : 'Parado' %>
      </span>
    </div>

    <!-- Health Check -->
    <div class="space-y-1">
      <p class="text-xs text-gray-500 uppercase tracking-wider">Health Check</p>
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full <%= status.healthCheck && status.healthCheck.active ? 'bg-vpn-400 pulse-dot' : 'bg-gray-600' %>"></span>
        <span class="text-sm font-medium <%= status.healthCheck && status.healthCheck.active ? 'text-vpn-400' : 'text-gray-500' %>">
          <%= status.healthCheck && status.healthCheck.active ? 'Monitorando' : 'Inativo' %>
        </span>
      </div>
      <% if (status.healthCheck && status.healthCheck.lastFix) { %>
        <p class="text-xs text-yellow-400/80" title="<%= status.healthCheck.lastFix.message %>">
          Ultima correcao: <%= status.healthCheck.lastFix.timestamp %>
        </p>
      <% } else if (status.healthCheck && status.healthCheck.active) { %>
        <p class="text-xs text-gray-600">Sem correcoes necessarias</p>
      <% } %>
    </div>

    <!-- Interface -->
    <div class="space-y-1">
      <p class="text-xs text-gray-500 uppercase tracking-wider">Interface</p>
      <span class="text-sm font-mono text-gray-300"><%= status.tunnel.iface || '-' %></span>
    </div>

    <!-- Port -->
    <div class="space-y-1">
      <p class="text-xs text-gray-500 uppercase tracking-wider">Port</p>
      <span class="text-sm font-mono text-gray-300"><%= status.tunnel.listenPort || '-' %></span>
    </div>
  </div>
</div>
